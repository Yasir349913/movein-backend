# ==========================================
# MOVEINN BACKEND ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and fill in your actual values

# ==========================================
# APPLICATION SETTINGS
# ==========================================
NODE_ENV=development
# NODE_ENV=production

PORT=5000
CLIENT_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000/api

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/moveinn
# Or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/moveinn

# Database Name
DB_NAME=moveinn

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Generate secure random strings for production
ACCESS_TOKEN_SECRET=your-super-secure-access-token-secret-here-min-32-chars
REFRESH_TOKEN_SECRET=your-super-secure-refresh-token-secret-here-min-32-chars
EMAIL_VERIFICATION_SECRET=your-super-secure-email-verification-secret-here

# Token Expiry Times
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ==========================================
# EMAIL CONFIGURATION (SMTP)
# ==========================================
# Email Service Provider (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email From Address
FROM_EMAIL=noreply@moveinn.com
FROM_NAME=Moveinn

# Email Settings
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=5000

# ==========================================
# FILE STORAGE (AWS S3)
# ==========================================
# AWS Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=moveinn-storage

# S3 Settings
S3_BASE_URL=https://moveinn-storage.s3.amazonaws.com

# ==========================================
# BACKGROUND CHECK API (CERTN)
# ==========================================
CERTN_API_URL=https://sandbox-api.certn.co
CERTN_API_KEY=your-certn-api-key
CERTN_CLIENT_ID=your-certn-client-id
CERTN_CLIENT_SECRET=your-certn-client-secret

# Background Check Webhook
CERTN_WEBHOOK_SECRET=your-certn-webhook-secret
BACKGROUND_CHECK_WEBHOOK_URL=https://yourdomain.com/api/webhooks/certn

# ==========================================
# PAYMENT PROCESSING (STRIPE)
# ==========================================
# Stripe Keys
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Stripe Connect (for landlord payouts)
STRIPE_CONNECT_CLIENT_ID=ca_your-stripe-connect-client-id

# Payment Settings
PLATFORM_FEE_PERCENTAGE=5.0
ESCROW_HOLD_DAYS=7

# ==========================================
# GOOGLE MAPS API
# ==========================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_GEOCODING_API_KEY=your-google-geocoding-api-key

# ==========================================
# ADMIN CREDENTIALS (FOR SEEDING)
# ==========================================
ADMIN_EMAIL=admin@moveinn.com
ADMIN_PASSWORD=SecureAdmin123!
SUPER_ADMIN_EMAIL=superadmin@moveinn.com
SUPER_ADMIN_PASSWORD=SuperSecureAdmin123!

# ==========================================
# UNIVERSITY PARTNERSHIPS
# ==========================================
# Default university subscription settings
DEFAULT_UNIVERSITY_FEE=99.00
DEFAULT_STUDENT_DISCOUNT=15.0

# ==========================================
# SECURITY SETTINGS
# ==========================================
# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits (in bytes)
MAX_FILE_SIZE=10485760
MAX_PROFILE_IMAGE_SIZE=5242880

# CORS Settings
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# ==========================================
# LOGGING & MONITORING
# ==========================================
LOG_LEVEL=info
# LOG_LEVEL=debug (for development)

# Error Tracking (Optional - Sentry, LogRocket, etc.)
SENTRY_DSN=your-sentry-dsn-url
LOGROCKET_APP_ID=your-logrocket-app-id

# ==========================================
# REDIS (OPTIONAL - FOR CACHING)
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password
CACHE_TTL=3600

# ==========================================
# EXTERNAL SERVICES
# ==========================================
# SMS Service (Twilio - Optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Push Notifications (FCM - Optional)
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-firebase-project-id

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================
# Mock external services in development
MOCK_CERTN_API=true
MOCK_STRIPE_PAYMENTS=true
MOCK_EMAIL_SENDING=false

# Debug Settings
DEBUG_WEBHOOKS=true
DEBUG_PAYMENTS=true
DEBUG_BACKGROUND_CHECKS=true

# ==========================================
# PRODUCTION SETTINGS
# ==========================================
# SSL/HTTPS
FORCE_HTTPS=true
SECURE_COOKIES=true

# Domain Settings
PRIMARY_DOMAIN=moveinn.com
API_DOMAIN=api.moveinn.com

# CDN Settings (Optional)
CDN_URL=https://cdn.moveinn.com

# ==========================================
# BACKUP & MAINTENANCE
# ==========================================
# Database Backup
DB_BACKUP_FREQUENCY=daily
DB_BACKUP_RETENTION_DAYS=30

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We're currently performing maintenance. Please try again later.

# ==========================================
# ANALYTICS & TRACKING (OPTIONAL)
# ==========================================
GOOGLE_ANALYTICS_ID=GA-XXXXX-X
MIXPANEL_TOKEN=your-mixpanel-token
HOTJAR_ID=your-hotjar-id