{
  "name": "storybook-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered personalized storybook generator for children",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "set NODE_NO_WARNINGS=1 && nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "seed": "node scripts/seed.js",
    "migrate": "node scripts/migrate.js",
    "queue:start": "node jobs/scheduler.js",
    "docs:generate": "swagger-jsdoc -d swaggerDef.js -o ./docs/swagger.json ./routes/*.js",
    "docs:serve": "swagger-ui-serve ./docs/swagger.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.850.0",
    "@aws-sdk/s3-request-presigner": "^3.850.0",
    "@faker-js/faker": "^9.9.0",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "cookie-parser": "^1.4.7",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "joi": "^17.12.1",
    "jsonwebtoken": "^9.0.1",
    "mongoose": "^8.3.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "openai": "^4.47.1",
    "pdf-lib": "^1.17.1",
    "redis": "^4.6.13",
    "sharp": "^0.33.2",
    "stripe": "^14.21.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "ai",
    "storybook",
    "children",
    "nodejs",
    "express",
    "mongodb",
    "openai",
    "pdf-generation",
    "image-generation"
  ],
  "author": "Abdul Aziz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:developer-tag/ai-story-book.git"
  },
  "bugs": {
    "url": "https://github.com/developer-tag/ai-story-book/issues"
  },
  "homepage": "https://github.com/developer-tag/ai-story-book#readme"
}
